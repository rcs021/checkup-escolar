# Configurações do banco de dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=checkup_escolar

# Configuração do JWT
JWT_SECRET=checkup_escolar_secret_key

# Porta do servidor backend
PORT=3001

# Configuração de e-mail (Nodemailer)
